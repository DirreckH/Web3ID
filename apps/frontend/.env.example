# Frontend environment defaults
# Copy to .env.local (or .env.test /.env.production) and adjust values.

VITE_APP_ENV=development
VITE_DATA_SOURCE=mock
VITE_API_BASE_URL=http://127.0.0.1:4200
VITE_ANVIL_RPC_URL=http://127.0.0.1:8545
# Required when VITE_CHAIN_ID=133 (HashKey Chain Testnet)
VITE_HASHKEY_TESTNET_RPC_URL=https://testnet.hsk.xyz
# Required when VITE_CHAIN_ID=56 (BNB Chain)
VITE_BNB_RPC_URL=https://bsc-dataseed.binance.org
VITE_CHAIN_ID=31337
VITE_ENABLE_ANALYTICS=false
