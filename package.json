{
  "name": "web3id-poc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -n issuer,frontend \"pnpm --filter @web3id/issuer-service dev\" \"pnpm --filter @web3id/frontend dev\"",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "contracts:test": "pnpm --dir contracts test",
    "proof:setup": "pnpm --filter @web3id/proof run setup",
    "demo:issue-vc": "pnpm --filter @web3id/issuer-service demo:issue",
    "demo:proof": "pnpm --filter @web3id/proof demo:proof",
    "demo:e2e": "pnpm --filter @web3id/frontend e2e",
    "demo:stage2": "tsx scripts/demo-stage2.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@playwright/test": "^1.51.0",
    "@types/snarkjs": "^0.7.9",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "viem": "^2.23.5",
    "vitest": "^3.0.9"
  }
}
